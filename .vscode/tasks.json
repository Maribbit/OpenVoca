{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "shared",
        "group": "servers"
      }
    },
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "uv run fastapi dev src/main.py",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "presentation": {
        "panel": "shared",
        "group": "servers"
      }
    },
    {
      "label": "🚀 Run OpenVoca (All)",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "group": {
        "kind": "build",
      }
    }
  ]
}