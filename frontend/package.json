    "check": "pnpm run typecheck && pnpm exec vitest run && pnpm build"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "jsdom": "^29.0.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.5"
  }
}
